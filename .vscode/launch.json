    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug",
            "type": "lldb",
            "request": "launch",
            "preLaunchTask": "build debug",
            "program": "${workspaceRoot}/zig-out/bin/special-relativity",
            "args": [
                "-s='./shaders'",
            ],
            "cwd": "${workspaceRoot}/zig-out/bin",
            "terminal": "console",
            "console": "internalConsole",
            "postDebugTask": "remove zig-out/bin/shaders",
        }
    ]
}
